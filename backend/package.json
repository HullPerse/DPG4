{
  "name": "backend",
  "version": "1.0.50",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "bun run --watch src/index.ts",
    "prod": "bun install && bun admin:build && bun run db:build && bun run server",
    "db:clear": "rm -f data/db.sqlite data/db.sqlite-wal data/db.sqlite-shm",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:restore": "bun run scripts/restore.ts",
    "db:studio": "drizzle-kit studio",
    "db:import-pocketbase": "bun run scripts/migrate-from-pb.ts",
    "db:build": "bun build --target bun --outfile server src/index.ts",
    "backup": "bun run scripts/backup.ts",
    "compress-images": "bun run scripts/compress-images.ts",
    "admin:install": "cd admin-panel && bun install",
    "admin:build": "cd admin-panel && bun install && bun run build"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/jwt": "^1.4.2",
    "@elysiajs/swagger": "^1.3.1",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "ioredis": "^5.11.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "bun-types": "latest",
    "drizzle-kit": "^0.31.10"
  },
  "module": "src/index.js"
}
