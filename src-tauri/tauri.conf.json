{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DPG 4",
  "version": "1.4.5",
  "identifier": "dpg4",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },

  "app": {
    "windows": [
      {
        "title": "DPG 4",
        "width": 960,
        "height": 840,
        "minWidth": 960,
        "minHeight": 840
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "windows": {
        "installMode": "passive"
      },
      "active": true,
      "dangerousInsecureTransportProtocol": true,
      "endpoints": [
        "https://github.com/HullPerse/DPG4/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY5NDVBQTdCQUUyOThENDkKUldSSmpTbXVlNnBGK2RqNU9NWEZVTk1GaXRQbHJpN0RSMGNWb1RQVzVrVHhKekNQVmNuUkJjWE0K"
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "createUpdaterArtifacts": true,
    "resources": ["assets/"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
